# Xcode user-specific data (signing, breakpoints, UI state)
*.xcuserdata/
*.xcuserstate
xcuserdata/

# Xcode build artifacts
DerivedData/
build/
*.xccheckout
*.moved-aside

# macOS system files
.DS_Store
*.swp
*~

# Temporary files
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Node.js (Firebase CLI / scripts)
node_modules/
package.json
package-lock.json

# Credentials — NEVER commit
serviceAccountKey.json
*.pem
*.key

# Temporary debug/test scripts (admin scripts like read/seed/wipe are intentionally tracked)
test*.js
test*.swift

# Firebase
firebase-debug.log
